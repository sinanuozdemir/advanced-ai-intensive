# Copy this to .env and fill in your keys before running `docker compose up`.
#
#   cp .env.example .env
#
# Only OPENROUTER_API_KEY is strictly required to boot. The MCP server keys
# are needed only for the tools you actually want to call (HubSpot/Resend/etc).

# ---------- Required ----------

# Used by the LLM in flask_app + celery worker.
OPENROUTER_API_KEY=sk-or-v1-...

# Flask session signing. Locally any string is fine; rotate for production.
SECRET_KEY=dev-secret-key-change-me

# ---------- MemoryAgent toggle ----------

# Set to 1 to use MemoryAgent (persistent checkpointer + semantic/episodic/procedural
# memory, /api/memory/* inspector + reflect). Sub-agents use scoped dirs under AGENT_DATA_ROOT.
# Leave unset / 0 to run the base GenericAgent.
USE_MEMORY_AGENT=1

# When 1 (default), prepend top semantic hits to each user message. Set 0 if you rely
# only on semantic_search to avoid doubling context.
# USE_MEMORY_AUTOPREFIX=1

# ---------- Supervisor toggle ----------

# When 1 (default), the chat endpoint talks to the SDR supervisor, which
# delegates to lead_gen / qualifier / email sub-agents via Celery. The UI
# dropdown still routes to per-config GenericAgents for debugging.
# Set to 0 to talk directly to whichever agent the dropdown selects.
USE_SUPERVISOR=1

# Model the supervisor uses for routing (cheap + decisive is best).
SUPERVISOR_MODEL=anthropic/claude-opus-4.6

# Optional: where MemoryAgent writes its semantic/episodic chroma + procedural
# sqlite + checkpoint sqlite. Defaults to <repo-root>/data/sdr_runtime.
# AGENT_DATA_ROOT=/path/to/persistent/dir

# When set, MemoryAgent's LangGraph checkpointer uses Postgres instead of
# SQLite. Production-recommended; uses the same `postgres` service as
# Celery results.
DATABASE_URL=postgresql://agent:agent123@postgres:5432/agent

# Celery broker. docker-compose.yml injects this for the worker + flask
# services pointing at the bundled RabbitMQ. Only set this here for non-Compose
# runs (e.g. running celery_app.py directly on the host) where the default
# `amqp://agent:agent123@localhost:5672/%2Fagent` would not resolve.
# CELERY_BROKER_URL=amqp://agent:agent123@rabbitmq:5672/%2Fagent

# Persistent Celery result backend (durable across reloads + multi-reader).
# Default rpc:// is one-shot — first reader drains the message and everyone
# else sees PENDING forever. Uses the `postgres` service in docker-compose.yml.
CELERY_RESULT_BACKEND=db+postgresql://agent:agent123@postgres:5432/agent

# ---------- MCP server keys (per-tool) ----------

# HubSpot CRM (private-app token).
HUBSPOT_API_KEY=pat-na1-...

# Research server: web search + scraping.
SERP_API_KEY=
FIRECRAWL_API_KEY=

# Email server (Resend).
RESEND_API_KEY=
SENDER_EMAIL_ADDRESS=you@example.com
# Comma-separated list (plural — that's what the email MCP server reads).
REPLY_TO_EMAIL_ADDRESSES=you@example.com

# ---------- Optional observability ----------

# Note: docker-compose.yml passes `${LANGSMITH_TRACING:-true}` to the worker
# and flask services, so leaving this UNSET in your shell makes tracing
# default to ON inside Compose. Set explicitly to false to disable.
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ai-agent-week2
