# Copy to `.env` and fill in. Anything left commented uses the in-code default.

# Required: OpenRouter key for every LLM call the workflow makes.
OPENROUTER_API_KEY=

# Required for real web search. Sign up at https://serpapi.com.
SERPAPI_API_KEY=

# Optional but strongly recommended for clean page extraction. Sign up at
# https://firecrawl.dev. Without it, the scraper falls back to a naive
# httpx GET + HTML strip, which works for static pages but not JS-heavy ones.
FIRECRAWL_API_KEY=

# Optional: per-stage models. plan/research/reflect default to a cheap
# workhorse; the artifact writer defaults to the frontier model since it
# produces the user-facing output.
# PLAN_MODEL=openai/gpt-5.4-mini
# RESEARCH_MODEL=openai/gpt-5.4-mini
# REFLECT_MODEL=openai/gpt-5.4-mini
# ARTIFACT_MODEL=anthropic/claude-opus-4.7

# Optional: max plan -> agent -> reflect rounds before forcing a finalize.
# MAX_ITERATIONS=3

# Optional: storage + observability.
# ARTIFACTS_DB_PATH=./runtime/artifacts.db
# LOG_FILE_PATH=./runtime/agent_api.log
# LOG_LEVEL=INFO

# Optional: distributed tracing. If set, langchain emits to LangSmith.
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=agent_api
