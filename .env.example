# Primary: one key gives access to every model used in the course
OPENROUTER_API_KEY=

# Optional: only needed if you want to bypass OpenRouter for a specific provider
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: agent search tools (SerpAPI) used in agent_api / workflow demos
SERPAPI_API_KEY=

# Required for cord_v2_receipt_sft.ipynb (Fireworks vision SFT + deploy)
FIREWORKS_API_KEY=
FIREWORKS_ACCOUNT_ID=

# Optional: tracing
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=advanced-agentic-ai
