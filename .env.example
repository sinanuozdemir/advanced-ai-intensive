# Optional: Week 1 nb 5 (web fallback / agent search tool examples) and Week 3 (search tools)
SERPAPI_API_KEY=

# Optional: tracing
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=advanced-agentic-ai
